generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  technical
  customer
  manager
}

enum CallStatus {
  open
  in_progress
  closed
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  password     String
  role         UserRole @default(customer)
  availability String[] @default([])
  avatar       String?
  
  createdCalls  Call[] @relation("CustomerCalls")
  assignedCalls Call[] @relation("TechnicianCalls")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("users")
}

model Service {
  id        String   @id @default(uuid())
  name      String
  basePrice Float

  active    Boolean @default(true)

  calls Call[]
  additionalServices CallAdditionalService[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("services")
}

model Call {
  id          String     @id @default(uuid())
  title       String
  description String
  status      CallStatus @default(open)

  customerId   String
  technicianId String
  serviceId    String

  // RELAÇÕES
 customer   User    @relation("CustomerCalls", fields: [customerId], references: [id], onDelete: Cascade)
  technician   User   @relation("TechnicianCalls", fields: [technicianId], references: [id])
  service    Service  @relation(fields: [serviceId], references: [id])  

  additionalServices CallAdditionalService[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("calls")
}

model CallAdditionalService {
  id        String   @id @default(uuid())
  callId    String
  serviceId String

  call      Call     @relation(fields: [callId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@map("call_additional_services")
}
