// This is your Prisma schema file,
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum UserRole {
  technical
  customer
  manager
}



model User {
  id String @id @default(uuid())
  name String
  email String @unique
  password String

  role UserRole @default(customer)
 

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")


  @@map("users")
}