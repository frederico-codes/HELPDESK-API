{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "outDir": "./dist",
    "rootDir": "./src",
     "types": ["node"],

    "module": "node16",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "prisma"]
}
